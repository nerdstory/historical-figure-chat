{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "historical-chat": {
      "root": ".",
      "framework": "flask",
      "entrypoint": "app:app"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "historical-chat"
      }
    }
  ]
}
